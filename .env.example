# Public site URL (used for sitemap, OG URLs). Set in Vercel to your production URL.
NEXT_PUBLIC_SITE_URL=https://www.australianmachinevision.com

# Contact form email via Web3Forms (browser-side; safe to expose publicly).
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key

# Optional: analytics (e.g. Vercel Analytics, Google Analytics).
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
